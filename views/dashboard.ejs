<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Admin Dashboard — Gold Estimation' }) %>

<body class="bg-gray-50 flex h-screen overflow-hidden sidebar-open" hx-boost="true">

    <%- include('partials/sidebar') %>

    <!-- MAIN -->
    <div class="flex-1 flex flex-col overflow-hidden relative">
        <header class="h-16 glass sticky top-0 z-30 flex items-center justify-between px-6 flex-shrink-0 border-b border-gray-100">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-100/50 hover:bg-gray-200 transition-colors text-xl">☰</button>
                <div class="md:hidden w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center text-xl shadow-lg">💎</div>
                <h2 class="text-lg font-bold text-gray-800 tracking-tight">Admin <span class="text-yellow-500">Dashboard</span></h2>
            </div>
            <button onclick="openModal('add-user-modal')"
                class="flex items-center gap-2 bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold text-sm px-4 py-2 rounded-xl transition shadow-sm h-10">
                <span>+</span> <span class="hidden md:inline">Add User</span>
            </button>
        </header>

        <!-- Main Body -->
        <main class="p-4 md:p-6 flex-1 overflow-auto space-y-6 custom-scrollbar">

            <!-- Stats -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
                <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl">👥</div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Total Users</p>
                        <p class="text-2xl font-black text-gray-800"><%= usersCount %></p>
                    </div>
                </div>
                <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-green-50 text-green-600 rounded-xl flex items-center justify-center text-2xl">📱</div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Live Devices</p>
                        <p class="text-2xl font-black text-gray-800"><%= activeSessions %></p>
                    </div>
                </div>
                <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-yellow-50 text-yellow-600 rounded-xl flex items-center justify-center text-2xl">⚡️</div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">On Trial</p>
                        <p class="text-2xl font-black text-gray-800"><%= trialCount %></p>
                    </div>
                </div>
            </div>

            <!-- Dashboard Content Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
                
                <!-- Main Content: Shop Owners Cards -->
                <div class="lg:col-span-3 space-y-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-xl font-bold text-gray-800">Shop Owners</h3>
                            <p class="text-xs text-gray-400 font-medium">Manage registrations and check sync status</p>
                        </div>
                        <div class="flex items-center gap-2 bg-white px-3 py-1.5 rounded-full border border-gray-100 shadow-sm text-[10px] font-black text-gray-500 uppercase tracking-tighter">
                            <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
                            <%= users.length %> Total
                        </div>
                    </div>

                    <!-- User Cards Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="user-list">
                        <% users.forEach(user => { %>
                            <%- include('partials/user-card', { user }) %>
                        <% }) %>
                    </div>

                    <% if (users.length === 0) { %>
                        <div class="bg-white rounded-3xl border-2 border-dashed border-gray-100 py-20 text-center">
                            <div class="text-4xl mb-4">🏪</div>
                            <p class="text-gray-400 text-sm font-medium">No shops registered yet.</p>
                        </div>
                    <% } %>
                </div>

                <!-- Sidebar Content: Active Sessions -->
                <div class="lg:col-span-1 border-gray-100 space-y-6">
                    <div class="flex items-center justify-between">
                        <h3 class="text-xl font-bold text-gray-800">Live Feed</h3>
                        <span class="text-[10px] font-black text-yellow-600 bg-yellow-50 px-2 py-1 rounded-full uppercase">Realtime</span>
                    </div>

                    <div class="space-y-4">
                        <% Object.keys(groupedSessions).forEach(shop => { %>
                            <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                                <div class="bg-gray-50/50 px-4 py-2.5 border-b border-gray-100 flex justify-between items-center">
                                    <span class="text-[10px] font-black text-gray-800 truncate uppercase tracking-tight"><%= shop %></span>
                                    <span class="bg-green-50 text-green-600 text-[9px] px-2 py-0.5 rounded-full font-black flex items-center gap-1">
                                        <span class="w-1 h-1 bg-green-500 rounded-full"></span> <%= groupedSessions[shop].length %>
                                    </span>
                                </div>
                                <div class="p-3 space-y-3">
                                    <% groupedSessions[shop].forEach(session => { %>
                                        <div class="flex items-start gap-3">
                                            <div class="w-8 h-8 rounded-xl bg-gray-50 flex items-center justify-center text-lg">📱</div>
                                            <div class="flex-1 overflow-hidden">
                                                <p class="text-[11px] font-bold text-gray-800 truncate"><%= session.device_name || 'Device' %></p>
                                                <p class="text-[9px] text-gray-400 truncate"><%= session.user.name %></p>
                                                <p class="text-[9px] text-yellow-600 font-black mt-1 uppercase">
                                                    <%= new Date(session.last_active).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                                                </p>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                        <% if (Object.keys(groupedSessions).length === 0) { %>
                            <div class="text-center py-10 bg-gray-50/50 rounded-2xl border border-dashed border-gray-200">
                                <p class="text-xs text-gray-400 font-medium italic">No active sessions</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- ADD USER MODAL -->
    <div id="add-user-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-300"
        onclick="closeModalOnBg(event, 'add-user-modal')">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden transform" onclick="event.stopPropagation()">
            <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-lg font-black text-gray-800 uppercase tracking-tight">Add New Shop Owner</h3>
                <button onclick="closeModal('add-user-modal')" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 transition-colors text-gray-400">✕</button>
            </div>
            <form hx-post="/admin/user/add" hx-target="#user-list" hx-swap="afterbegin"
                hx-on::after-request="closeModal('add-user-modal')" 
                data-toast="Shop owner added successfully!"
                class="p-6 space-y-5">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Owner Name</label>
                        <input type="text" name="name" required placeholder="Full Name" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Shop Name</label>
                        <input type="text" name="shop_name" placeholder="Business Name" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Phone Number</label>
                        <input type="text" name="phone" required placeholder="978833xxxx" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Initial Password</label>
                        <input type="text" name="password" placeholder="Welcome@123" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Device Limit</label>
                        <input type="number" name="max_allowed_devices" value="1" min="1" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Trial Period (Days)</label>
                        <input type="number" name="trial_days" value="7" min="1" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                    </div>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="closeModal('add-user-modal')"
                        class="flex-1 py-3.5 border border-gray-200 text-gray-600 rounded-2xl text-xs font-bold hover:bg-gray-50 transition-colors uppercase tracking-widest">Cancel</button>
                    <button type="submit"
                        class="flex-1 py-3.5 bg-yellow-400 shadow-xl shadow-yellow-200 hover:bg-yellow-500 text-gray-900 font-black rounded-2xl text-xs transition-transform active:scale-95 uppercase tracking-widest">Register Shop</button>
                </div>
            </form>
        </div>
    </div>

    <!-- EDIT USER MODAL -->
    <div id="edit-user-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-300"
        onclick="closeModalOnBg(event, 'edit-user-modal')">
        <div id="edit-modal-content" class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden transform" onclick="event.stopPropagation()">
            <!-- Loaded via HTMX -->
        </div>
    </div>

    <%- include('partials/bottom-nav') %>
    <%- include('partials/toast') %>

    <script>
        function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
        function closeModalOnBg(e, id) { if (e.target === e.currentTarget) closeModal(id); }

        function openEditModal(userId) {
            document.getElementById('edit-user-modal').classList.remove('hidden');
            htmx.ajax('GET', `/admin/user/${userId}/edit-form`, { target: '#edit-modal-content' });
        }
    </script>
</body>

</html>