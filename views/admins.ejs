<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Manage Admins | MNVG Gold' }) %>

<body class="bg-gray-50 flex h-screen overflow-hidden sidebar-open" hx-boost="true">

    <%- include('partials/sidebar') %>

    <!-- MAIN -->
    <div class="flex-1 flex flex-col overflow-hidden relative">
        <header class="h-16 glass sticky top-0 z-30 flex items-center justify-between px-6 flex-shrink-0 border-b border-gray-100">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-100/50 hover:bg-gray-200 transition-colors text-xl">☰</button>
                <a href="/admin" class="text-gray-400 hover:text-gray-800 transition-colors">🏠</a>
                <h2 class="text-lg font-bold text-gray-800 tracking-tight">System <span class="text-yellow-500">Admins</span></h2>
            </div>
            <button onclick="openModal('add-admin-modal')"
                class="flex items-center gap-2 bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold text-sm px-4 py-2 rounded-xl transition shadow-sm h-10">
                <span>+</span> <span class="hidden md:inline">Add Admin</span>
            </button>
        </header>

        <main class="p-4 md:p-6 flex-1 overflow-auto space-y-6 custom-scrollbar">
            
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/30">
                    <h3 class="text-sm font-black text-gray-800 uppercase tracking-widest">Administrative Team</h3>
                    <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest"><%= admins.length %> Personnel</span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-50/50 text-gray-400 text-[10px] uppercase font-black border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Identity</th>
                                <th class="px-6 py-4">Role</th>
                                <th class="px-6 py-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50" id="admin-list">
                            <% admins.forEach(user => { %>
                                <%- include('partials/admin-row', { user }) %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- ADD ADMIN MODAL -->
    <div id="add-admin-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-300"
        onclick="closeModalOnBg(event, 'add-admin-modal')">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform" onclick="event.stopPropagation()">
            <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-lg font-black text-gray-800 uppercase tracking-tight">Create Admin Account</h3>
                <button onclick="closeModal('add-admin-modal')" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 transition-colors text-gray-400">✕</button>
            </div>
            <form hx-post="/admin/admins/add" hx-target="#admin-list" hx-swap="afterbegin"
                hx-on::after-request="closeModal('add-admin-modal')" 
                data-toast="Admin created successfully!"
                class="p-6 space-y-5">
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Phone Number (Login)</label>
                    <input type="text" name="phone" required placeholder="978833xxxx" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Secure Password</label>
                    <input type="password" name="password" required placeholder="••••••••" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Access Tier</label>
                    <select name="role" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                        <option value="admin">Standard Admin</option>
                        <option value="super_admin">Super Administrator</option>
                    </select>
                </div>
                <div class="flex gap-3 pt-4">
                    <button type="button" onclick="closeModal('add-admin-modal')"
                        class="flex-1 py-3.5 border border-gray-200 text-gray-600 rounded-2xl text-xs font-bold hover:bg-gray-50 transition-colors uppercase tracking-widest">Cancel</button>
                    <button type="submit"
                        class="flex-1 py-3.5 bg-yellow-400 shadow-xl shadow-yellow-200 hover:bg-yellow-500 text-gray-900 font-black rounded-2xl text-xs transition-transform active:scale-95 uppercase tracking-widest">Deploy Admin</button>
                </div>
            </form>
        </div>
    </div>

    <!-- EDIT MODAL -->
    <div id="edit-admin-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-300"
        onclick="closeModalOnBg(event, 'edit-admin-modal')">
        <div id="edit-admin-content" class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform" onclick="event.stopPropagation()"></div>
    </div>

    <%- include('partials/bottom-nav') %>
    <%- include('partials/toast') %>

    <script>
        function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
        function closeModalOnBg(e, id) { if (e.target === e.currentTarget) closeModal(id); }

        function openEditAdmin(id) {
            openModal('edit-admin-modal');
            htmx.ajax('GET', `/admin/admins/${id}/edit-form`, { target: '#edit-admin-content' });
        }
    </script>
</body>

</html>
