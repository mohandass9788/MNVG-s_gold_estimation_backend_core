<!-- views/partials/sidebar.ejs -->
<div id="sidebar-overlay" onclick="toggleSidebar()"></div>
<aside id="sidebar" class="w-64 bg-gray-900 flex-col flex-shrink-0 fixed md:relative inset-y-0 left-0 z-[100] flex shadow-2xl transition-all duration-300 ease-in-out">
    <div class="h-16 flex items-center justify-between px-6 border-b border-white/10 shrink-0">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center text-xl shadow-lg shadow-yellow-400/20">💎</div>
            <div>
                <p class="text-white font-bold text-sm tracking-tight text-nowrap">MNVG Gold</p>
                <p class="text-gray-500 text-[10px] uppercase font-bold tracking-widest text-nowrap">Admin Panel</p>
            </div>
        </div>
        <button onclick="toggleSidebar()" class="md:hidden text-gray-500 hover:text-white transition-colors">✕</button>
    </div>
    <nav class="flex-1 p-4 space-y-1.5 overflow-y-auto custom-scrollbar">
        <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/10 transition-all duration-200 group text-sm font-medium">
            <span class="text-lg opacity-70 group-hover:opacity-100">🏠</span> Dashboard
        </a>
        
        <% if (admin && admin.role === 'super_admin') { %>
        <a href="/admin/admins" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/10 transition-all duration-200 group text-sm font-medium">
            <span class="text-lg opacity-70 group-hover:opacity-100">🛡️</span> Manage Admins
        </a>
        
        <a href="/admin/config" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/10 transition-all duration-200 group text-sm font-medium">
            <span class="text-lg opacity-70 group-hover:opacity-100">⚙️</span> App Config
        </a>

        <a href="/admin/logs" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/10 transition-all duration-200 group text-sm font-medium">
            <span class="text-lg opacity-70 group-hover:opacity-100">📋</span> App Logs
        </a>
        <% } %>
    </nav>
    <div class="p-4 border-t border-white/10">
        <button onclick="openModal('logout-modal')" class="w-full flex items-center gap-3 px-4 py-2.5 rounded-xl text-red-400 hover:bg-red-500/10 transition-all duration-200 text-sm font-medium">
            <span class="text-lg">🚪</span> Log Out
        </button>
    </div>
</aside>

<!-- Logout Confirmation Modal -->
<div id="logout-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4 transition-all duration-300" onclick="closeModalOnBg(event, 'logout-modal')">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden transform" onclick="event.stopPropagation()">
        <div class="p-8 text-center">
            <div class="w-20 h-20 bg-red-50 text-red-500 rounded-full flex items-center justify-center text-4xl mx-auto mb-6 shadow-inner">🚪</div>
            <h3 class="text-xl font-black text-gray-800 uppercase tracking-tight mb-2">Confirm Logout</h3>
            <p class="text-sm text-gray-500 font-medium mb-8">Are you sure you want to end your session? You'll need to sign in again to access the dashboard.</p>
            
            <div class="flex gap-3">
                <button onclick="closeModal('logout-modal')" 
                    class="flex-1 py-3.5 border border-gray-100 text-gray-600 rounded-2xl text-xs font-bold hover:bg-gray-50 transition-colors uppercase tracking-widest">Cancel</button>
                <a href="/admin/logout" hx-boost="false"
                    class="flex-1 py-3.5 bg-red-500 shadow-xl shadow-red-100 hover:bg-red-600 text-white font-black rounded-2xl text-xs transition-transform active:scale-95 uppercase tracking-widest text-center">Yes, Log Out</a>
            </div>
        </div>
    </div>
</div>
