<tr class="hover:bg-gray-50 text-sm transition" id="user-row-<%= user.id %>">
    <!-- Name / Shop -->
    <td class="px-6 py-4">
        <div>
            <p class="font-semibold text-gray-800">
                <%= user.name || '—' %>
            </p>
            <p class="text-xs text-gray-400 mt-0.5">
                <%= user.shop_name || 'No shop name' %>
            </p>
        </div>
    </td>

    <!-- Phone -->
    <td class="px-6 py-4 text-gray-600 font-medium">
        <%= user.phone %>
    </td>

    <!-- Subscription -->
    <td class="px-6 py-4">
        <% const expDate=user.subscription_valid_upto ? new Date(user.subscription_valid_upto) : null; const
            isExpired=!expDate || expDate < new Date(); const dateStr=expDate ? expDate.toLocaleDateString('en-IN')
            : 'No date' ; %>
            <span
                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold
            <%= isExpired ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
                <span>
                    <%= isExpired ? '🔴' : '🟢' %>
                </span>
                <%= dateStr %>
                    <%= user.is_trial ? ' (Trial)' : '' %>
            </span>

            <!-- Extend form -->
            <form hx-post="/admin/user/<%= user.id %>/extend" hx-target="#user-row-<%= user.id %>" hx-swap="outerHTML"
                data-toast="Subscription extended!" class="inline-flex items-center gap-1 mt-1">
                <select name="days"
                    class="text-xs border border-gray-200 rounded px-1.5 py-1 focus:outline-none focus:border-yellow-400">
                    <option value="30">+1M</option>
                    <option value="90">+3M</option>
                    <option value="180">+6M</option>
                    <option value="365">+1Y</option>
                </select>
                <button type="submit"
                    class="text-xs bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-2 py-1 rounded transition">Extend</button>
            </form>
    </td>

    <!-- Max Devices -->
    <td class="px-6 py-4">
        <form hx-post="/admin/user/<%= user.id %>/devices" hx-target="#user-row-<%= user.id %>" hx-swap="outerHTML"
            data-toast="Device limit updated!" class="flex items-center gap-2">
            <input type="number" name="max_allowed_devices" value="<%= user.max_allowed_devices %>" min="1" max="20"
                class="w-14 border border-gray-200 rounded px-2 py-1 text-center text-xs focus:outline-none focus:border-yellow-400">
            <button type="submit"
                class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 px-2 py-1 rounded transition">✓</button>
        </form>
    </td>

    <!-- Actions -->
    <td class="px-6 py-4">
        <div class="flex items-center gap-2">
            <!-- Customers -->
            <a href="/admin/user/<%= user.id %>/customers"
                class="text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 px-3 py-1.5 rounded-lg transition font-medium">
                👥 Customers
            </a>
            <!-- Edit -->
            <button onclick="openEditModal('<%= user.id %>')"
                class="text-xs bg-yellow-50 hover:bg-yellow-100 text-yellow-700 px-3 py-1.5 rounded-lg transition font-medium">
                ✏️ Edit
            </button>
            <!-- Delete -->
            <button hx-delete="/admin/user/<%= user.id %>" hx-target="#user-row-<%= user.id %>" hx-swap="outerHTML"
                hx-confirm="Delete <%= user.name || user.phone %>? This will remove ALL their data."
                data-toast="User deleted."
                class="text-xs bg-red-50 hover:bg-red-100 text-red-700 px-3 py-1.5 rounded-lg transition font-medium">
                🗑 Delete
            </button>
        </div>
    </td>
</tr>