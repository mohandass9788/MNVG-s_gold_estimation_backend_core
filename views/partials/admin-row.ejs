<tr class="hover:bg-gray-50 text-sm transition" id="admin-row-<%= user.id %>">
    <td class="px-6 py-4">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-xs">
                <%= user.name ? user.name.charAt(0).toUpperCase() : 'A' %>
            </div>
            <div>
                <p class="font-semibold text-gray-800"><%= user.name || 'Admin' %></p>
                <p class="text-xs text-gray-400">Created <%= user.created_at ? new Date(user.created_at).toLocaleDateString('en-IN') : '—' %></p>
            </div>
        </div>
    </td>
    <td class="px-6 py-4 text-gray-600 font-medium">
        <%= user.phone %>
    </td>
    <td class="px-6 py-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
            <%= user.role === 'super_admin' ? 'Super Admin' : 'Admin' %>
        </span>
    </td>
    <td class="px-6 py-4 text-right">
        <div class="flex items-center justify-end gap-2">
            <button onclick="openEditAdminModal('<%= user.id %>')"
                class="text-xs bg-yellow-50 hover:bg-yellow-100 text-yellow-700 px-3 py-1.5 rounded-lg transition font-medium">
                ✏️ Edit
            </button>
            <% if (user.role !== 'super_admin' || user.id !== admin.id) { %>
                <button hx-delete="/admin/admins/<%= user.id %>" hx-target="#admin-row-<%= user.id %>" hx-swap="outerHTML"
                    hx-confirm="Delete admin <%= user.name || user.phone %>?"
                    data-toast="Admin deleted."
                    class="text-xs bg-red-50 hover:bg-red-100 text-red-700 px-3 py-1.5 rounded-lg transition font-medium">
                    🗑 Delete
                </button>
            <% } %>
        </div>
    </td>
</tr>
