<tr class="hover:bg-gray-50/50 text-sm transition group" id="admin-row-<%= user.id %>">
    <td class="px-6 py-4">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-gray-900 flex items-center justify-center text-white font-black text-[10px] shadow-lg shadow-gray-200">
                <%= user.name ? user.name.charAt(0).toUpperCase() : 'A' %>
            </div>
            <div>
                <p class="font-black text-gray-800 uppercase tracking-tighter text-sm italic leading-none"><%= user.name || 'System User' %></p>
                <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest mt-1">Joined <%= user.created_at ? new Date(user.created_at).toLocaleDateString() : '--' %></p>
            </div>
        </div>
    </td>
    <td class="px-6 py-4">
        <div class="flex items-center gap-2 group/pass relative">
            <p class="text-[11px] font-black text-gray-800 font-mono tracking-tighter blur-[4px] transition-all" id="pass-<%= user.id %>">
                <%= user.phone %> <span class="mx-0.5 text-gray-300">•</span> <%= user.plain_password || '[RESET TO VIEW]' %>
            </p>
            <button onclick="document.getElementById('pass-<%= user.id %>').classList.toggle('blur-[4px]')" 
                class="w-6 h-6 flex items-center justify-center rounded-lg bg-gray-50 border border-gray-100 opacity-0 group-hover/pass:opacity-100 transition-all text-[8px]" title="Toggle">👁️</button>
        </div>
    </td>
    <td class="px-6 py-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest <%= user.role === 'super_admin' ? 'bg-purple-50 text-purple-600 border border-purple-100' : 'bg-gray-50 text-gray-600 border border-gray-200' %>">
            <%= user.role === 'super_admin' ? '⚡️ Super Admin' : '👤 Admin' %>
        </span>
    </td>
    <td class="px-6 py-4 text-right">
        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button onclick="openEditAdmin('<%= user.id %>')"
                class="w-8 h-8 flex items-center justify-center rounded-full bg-yellow-50 text-yellow-600 hover:bg-yellow-400 hover:text-gray-900 transition-colors">
                ✏️
            </button>
            <% if (user.role !== 'super_admin' || (typeof admin !== 'undefined' && user.id !== admin.id)) { %>
                <button hx-delete="/admin/admins/<%= user.id %>" hx-target="#admin-row-<%= user.id %>" hx-swap="outerHTML"
                    hx-confirm="Permanently delete this administrator?"
                    data-toast="Personnel removed."
                    class="w-8 h-8 flex items-center justify-center rounded-full bg-red-50 text-red-400 hover:bg-red-500 hover:text-white transition-colors">
                    🗑
                </button>
            <% } %>
        </div>
    </td>
</tr>
