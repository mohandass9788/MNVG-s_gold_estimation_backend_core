<div class="flex flex-col h-full">
    <div class="px-8 py-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-500 flex items-center justify-center text-white shadow-xl shadow-blue-100 text-xl font-black italic">
                <%= customer.name.charAt(0).toUpperCase() %>
            </div>
            <div>
                <h3 class="text-xl font-black text-gray-800 uppercase tracking-tight leading-tight"><%= customer.name %></h3>
                <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest mt-1">Client Profile • Joined <%= new Date(customer.created_at || Date.now()).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }) %></p>
            </div>
        </div>
        <button onclick="closeModal('detail-modal')" class="w-10 h-10 flex items-center justify-center rounded-2xl hover:bg-gray-200 transition-colors text-gray-400 text-lg">✕</button>
    </div>
    
    <div class="p-8 overflow-auto custom-scrollbar space-y-10">
        <!-- Stats Grid -->
        <div class="grid grid-cols-3 gap-4">
            <div class="bg-white p-5 border border-gray-100 rounded-3xl shadow-sm text-center">
                <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Estimations</p>
                <p class="text-2xl font-black text-gray-800"><%= customer._count.estimation %></p>
            </div>
            <div class="bg-white p-5 border border-gray-100 rounded-3xl shadow-sm text-center">
                <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Purchases</p>
                <p class="text-2xl font-black text-green-600"><%= customer._count.purchase %></p>
            </div>
            <div class="bg-white p-5 border border-gray-100 rounded-3xl shadow-sm text-center">
                <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Repairs</p>
                <p class="text-2xl font-black text-orange-500"><%= customer._count.repair %></p>
            </div>
        </div>

        <!-- Details Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div class="space-y-1">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest border-l-2 border-blue-500 pl-2">Contact Information</p>
                    <div class="p-5 bg-gray-50 rounded-2xl space-y-3">
                        <div class="flex items-center justify-between">
                            <span class="text-[10px] text-gray-400 font-bold uppercase">Phone</span>
                            <span class="text-sm font-black text-gray-800"><%= customer.phone || 'N/A' %></span>
                        </div>
                        <div class="flex items-center justify-between border-t border-gray-100 pt-3">
                            <span class="text-[10px] text-gray-400 font-bold uppercase">Total Visits</span>
                            <span class="text-sm font-black text-blue-600"><%= customer.total_visits || 0 %></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="space-y-1">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest border-l-2 border-gray-200 pl-2">Home Address</p>
                    <div class="p-5 bg-gray-50 rounded-2xl">
                        <p class="text-sm font-medium text-gray-700 italic leading-relaxed">
                            "<%= customer.address || 'No address provided in system.' %>"
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Summary -->
        <div class="bg-gray-900 p-8 rounded-[2.5rem] shadow-2xl shadow-gray-200 relative overflow-hidden group">
            <div class="absolute -right-10 -top-10 text-white/5 text-9xl font-black italic group-hover:scale-110 transition-transform duration-700">VIP</div>
            <div class="relative z-10 flex items-center justify-between">
                <div>
                    <p class="text-[10px] text-yellow-400 font-black uppercase tracking-[0.2em] mb-2">Customer Value Status</p>
                    <h4 class="text-3xl font-black text-white tracking-tighter italic uppercase">Loyal Client</h4>
                </div>
                <div class="text-right">
                    <p class="text-[10px] text-white/40 font-black uppercase tracking-widest mb-1">Local ID</p>
                    <p class="text-xs font-mono text-white/60"><%= customer.local_id %></p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="px-8 py-6 bg-gray-50/50 border-t border-gray-100 flex justify-between items-center">
        <p class="text-[10px] text-gray-400 font-medium italic">Database ID: <%= customer.id %></p>
        <button onclick="closeModal('detail-modal')"
            class="px-8 py-3 bg-gray-900 text-white font-black rounded-2xl text-[10px] uppercase tracking-widest hover:bg-gray-800 transition-all shadow-lg shadow-gray-200 active:scale-95">
            Close Profile
        </button>
    </div>
</div>
