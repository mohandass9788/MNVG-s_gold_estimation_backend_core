<tr class="hover:bg-gray-50/50 text-sm transition group cursor-pointer" id="purchase-row-<%= p.id %>" onclick="openPurchaseDetails('<%= p.id %>')">
    <td class="px-6 py-4 whitespace-nowrap">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center text-green-600 font-black text-[10px]">
                #<%= p.bill_no %>
            </div>
            <div>
                <p class="font-black text-gray-800 uppercase tracking-tighter text-[13px] leading-tight"><%= p.customer_name %></p>
                <p class="text-[10px] text-gray-400 font-medium tracking-tight"><%= p.local_id %></p>
            </div>
        </div>
    </td>
    <td class="px-6 py-4 text-gray-500 font-bold text-[11px] tracking-tight whitespace-nowrap">
        <%= p.customer_phone || '—' %>
    </td>
    <td class="px-6 py-4 text-gray-900 font-black text-[12px] tracking-tighter">
        ₹<%= p.total_amount.toLocaleString('en-IN') %>
    </td>
    <td class="px-6 py-4">
        <% 
            let items = [];
            try { items = typeof p.items === 'string' ? JSON.parse(p.items) : p.items || []; } catch(e){}
        %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black bg-gray-50 text-gray-600 border border-gray-100 uppercase tracking-widest">
            <%= items.length %> Items
        </span>
    </td>
    <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button hx-delete="/admin/purchase/<%= p.id %>" hx-target="#purchase-row-<%= p.id %>"
                hx-swap="outerHTML" hx-confirm="Delete purchase record?" data-toast="Record removed."
                class="w-8 h-8 flex items-center justify-center rounded-full bg-red-50 text-red-400 hover:bg-red-500 hover:text-white transition-colors shadow-sm">
                🗑
            </button>
        </div>
    </td>
</tr>
