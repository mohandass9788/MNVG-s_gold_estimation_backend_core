<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login — Gold Estimation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .gold-gradient {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        }

        .btn-gold {
            background: linear-gradient(135deg, #f5c842, #e0a020);
        }

        .btn-gold:hover {
            background: linear-gradient(135deg, #f0b800, #d09000);
            transform: translateY(-1px);
        }

        input:focus {
            box-shadow: 0 0 0 3px rgba(245, 200, 66, 0.25);
        }
    </style>
</head>

<body class="gold-gradient min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-yellow-400 shadow-lg mb-4">
                <span class="text-3xl">💎</span>
            </div>
            <h1 class="text-3xl font-bold text-white">Gold Estimation</h1>
            <p class="text-blue-300 mt-1 text-sm">Admin Control Panel</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <h2 class="text-xl font-bold text-gray-800 mb-6">Sign In</h2>

            <% if (error) { %>
                <div
                    class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm flex items-center gap-2">
                    <span>⚠️</span>
                    <%= error %>
                </div>
                <% } %>

                    <form method="POST" action="/admin/login" class="space-y-5">
                        <% if (locals.next) { %>
                            <input type="hidden" name="next" value="<%= next %>">
                        <% } %>
                        <div>

                            <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                            <input type="tel" name="phone" id="phone" required maxlength="10" pattern="[0-9]{10}" placeholder="9876543210"
                                oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10)"
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-yellow-400 transition">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                            <div class="relative">
                                <input type="password" name="password" id="password" required
                                    placeholder="Enter password"
                                    class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:border-yellow-400 transition pr-12">
                                <button type="button" onclick="togglePassword()"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 text-lg">👁</button>
                            </div>
                        </div>
                        <button type="submit"
                            class="btn-gold w-full py-3 rounded-xl text-gray-900 font-semibold text-sm transition shadow-md">
                            Sign In to Dashboard
                        </button>
                    </form>
        </div>

        <p class="text-center text-blue-300/60 text-xs mt-6">MNV Groups © 2026</p>
    </div>

    <script>
        function togglePassword() {
            const p = document.getElementById('password');
            p.type = p.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>

</html>