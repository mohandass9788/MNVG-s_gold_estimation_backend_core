<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customers — <%= user.name %> | Admin</title>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        #toast {
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.3s;
        }

        #toast.show {
            transform: translateY(0);
            opacity: 1;
        }
    </style>
</head>

<body class="bg-gray-100 flex h-screen overflow-hidden">

    <!-- ── SIDEBAR ── -->
    <aside class="w-64 bg-gray-900 flex flex-col flex-shrink-0">
        <div class="h-16 flex items-center gap-3 px-6 border-b border-white/10">
            <span class="text-2xl">💎</span>
            <div>
                <p class="text-white font-bold text-sm">Gold Admin</p>
                <p class="text-gray-500 text-xs">MNV Groups</p>
            </div>
        </div>
        <nav class="flex-1 p-4 space-y-1">
            <a href="/admin"
                class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/10 transition text-sm">
                <span>🏠</span> Dashboard
            </a>
            <% if (admin && admin.role === 'super_admin') { %>
            <a href="/admin/admins"
                class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-white/10 transition text-sm">
                <span>🛡️</span> Admins
            </a>
            <% } %>
        </nav>
        <div class="p-4 border-t border-white/10">
            <a href="/admin/logout" class="flex items-center gap-2 text-red-400 hover:text-red-300 text-xs transition">
                <span>🚪</span> Logout
            </a>
        </div>
    </aside>

    <!-- ── MAIN ── -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="h-16 bg-white border-b border-gray-100 flex items-center justify-between px-6 flex-shrink-0">
            <div class="flex items-center gap-3">
                <a href="/admin" class="text-gray-400 hover:text-gray-600 text-sm transition">← Back</a>
                <div class="w-px h-5 bg-gray-200"></div>
                <div>
                    <h2 class="text-base font-bold text-gray-800">Customers — <%= user.name || user.phone %>
                    </h2>
                    <p class="text-xs text-gray-400">
                        <%= user.shop_name || '' %>
                    </p>
                </div>
            </div>
            <button onclick="openModal('add-customer-modal')"
                class="flex items-center gap-2 bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold text-sm px-4 py-2 rounded-lg transition shadow-sm">
                <span>+</span> Add Customer
            </button>
        </header>

        <main class="p-6 flex-1 overflow-auto">
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h3 class="font-bold text-gray-800">Customer List</h3>
                    <span class="text-xs text-gray-400" id="cust-count">
                        <%= customers.length %> customers
                    </span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                            <tr>
                                <th class="px-6 py-3 font-semibold">Name</th>
                                <th class="px-6 py-3 font-semibold">Phone</th>
                                <th class="px-6 py-3 font-semibold">Address</th>
                                <th class="px-6 py-3 font-semibold">Visits</th>
                                <th class="px-6 py-3 font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50" id="customer-list">
                            <% customers.forEach(customer=> { %>
                                <%- include('partials/customer-row', { customer }) %>
                                    <% }) %>
                        </tbody>
                    </table>
                </div>
                <% if (customers.length===0) { %>
                    <div class="text-center py-12 text-gray-400 text-sm">No customers yet. Click "+ Add Customer" to add
                        one.</div>
                    <% } %>
            </div>
        </main>
    </div>

    <!-- ── ADD CUSTOMER MODAL ── -->
    <div id="add-customer-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
        onclick="closeModalOnBg(event, 'add-customer-modal')">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6" onclick="event.stopPropagation()">
            <div class="flex justify-between items-center mb-5">
                <h3 class="text-lg font-bold text-gray-800">Add Customer</h3>
                <button onclick="closeModal('add-customer-modal')"
                    class="text-gray-400 hover:text-gray-600 text-xl">✕</button>
            </div>
            <form hx-post="/admin/customer/add" hx-target="#customer-list" hx-swap="afterbegin"
                hx-on::after-request="closeModal('add-customer-modal'); showToast('Customer added!')" class="space-y-4">
                <input type="hidden" name="userId" value="<%= user.id %>">
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Full Name <span
                            class="text-red-400">*</span></label>
                    <input type="text" name="name" required placeholder="Customer name"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-yellow-400">
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Phone</label>
                    <input type="text" name="phone" placeholder="Mobile number"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-yellow-400">
                </div>
                <div>
                    <label class="text-xs font-medium text-gray-600 block mb-1">Address</label>
                    <textarea name="address" rows="2" placeholder="Customer address"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-yellow-400 resize-none"></textarea>
                </div>
                <div class="flex gap-3 pt-1">
                    <button type="button" onclick="closeModal('add-customer-modal')"
                        class="flex-1 py-2.5 border border-gray-200 text-gray-600 rounded-lg text-sm hover:bg-gray-50 transition">Cancel</button>
                    <button type="submit"
                        class="flex-1 py-2.5 bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold rounded-lg text-sm transition">Add</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ── EDIT CUSTOMER MODAL ── -->
    <div id="edit-customer-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
        onclick="closeModalOnBg(event, 'edit-customer-modal')">
        <div id="edit-customer-content" class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6"
            onclick="event.stopPropagation()">
            <!-- loaded by htmx -->
        </div>
    </div>

    <!-- ── TOAST ── -->
    <div id="toast"
        class="fixed bottom-6 right-6 bg-gray-900 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50 flex items-center gap-2">
        <span>✅</span> <span id="toast-msg">Done!</span>
    </div>

    <script>
        function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
        function closeModalOnBg(e, id) { if (e.target === e.currentTarget) closeModal(id); }

        function openEditCustomer(id) {
            openModal('edit-customer-modal');
            htmx.ajax('GET', `/admin/customer/${id}/edit-form`, { target: '#edit-customer-content' });
        }

        function showToast(msg) {
            const t = document.getElementById('toast');
            document.getElementById('toast-msg').textContent = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        }

        document.body.addEventListener('htmx:afterRequest', (e) => {
            if (e.detail.successful && e.detail.elt.dataset.toast) {
                showToast(e.detail.elt.dataset.toast);
            }
        });
    </script>
</body>

</html>