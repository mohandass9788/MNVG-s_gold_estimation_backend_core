<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Customer Directory | MNVG Gold' }) %>

<body class="bg-gray-50 flex h-screen overflow-hidden sidebar-open" hx-boost="true">

    <%- include('partials/sidebar') %>

    <!-- MAIN -->
    <div class="flex-1 flex flex-col overflow-hidden relative">
        <header class="h-16 glass sticky top-0 z-30 flex items-center justify-between px-6 flex-shrink-0 border-b border-gray-100">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-100/50 hover:bg-gray-200 transition-colors text-xl">☰</button>
                <a href="/admin" class="text-gray-400 hover:text-gray-800 transition-colors text-lg">←</a>
                <div class="h-5 w-px bg-gray-200"></div>
                <div>
                    <h2 class="text-base font-bold text-gray-800 tracking-tight leading-none"><%= user.shop_name %></h2>
                    <p class="text-[10px] text-gray-400 font-black uppercase tracking-widest mt-0.5"><%= user.name %></p>
                </div>
            </div>
            <button onclick="openModal('add-customer-modal')"
                class="bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-bold text-xs px-4 py-2 rounded-xl transition shadow-lg shadow-yellow-200">
                <span class="md:hidden">+ Customer</span>
                <span class="hidden md:inline">+ Add Customer</span>
            </button>
        </header>

        <main class="p-4 md:p-6 flex-1 overflow-auto space-y-6 custom-scrollbar">

            <!-- Stats Grid -->
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
                <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Customers</p>
                    <p class="text-xl font-black text-gray-800"><%= user._count.customer %></p>
                </div>
                <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Estimations</p>
                    <p class="text-xl font-black text-gray-800"><%= user._count.estimation %></p>
                </div>
                <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Purchases</p>
                    <p class="text-xl font-black text-gray-800"><%= user._count.purchase %></p>
                </div>
                <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Repairs</p>
                    <p class="text-xl font-black text-gray-800"><%= user._count.repair %></p>
                </div>
                <div class="hidden md:block bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                    <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1">Staff</p>
                    <p class="text-xl font-black text-gray-800"><%= user._count.employee %></p>
                </div>
            </div>

            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/30">
                    <h3 class="text-sm font-black text-gray-800 uppercase tracking-widest">Client Directory</h3>
                    <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest" id="cust-count">
                        <%= customers.length %> Entries
                    </span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-50/50 text-gray-400 text-[10px] uppercase font-black border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-4">Customer</th>
                                <th class="px-6 py-4">Phone</th>
                                <th class="px-6 py-4 hidden md:table-cell">Address</th>
                                <th class="px-6 py-4">Activity</th>
                                <th class="px-6 py-4">Manage</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50" id="customer-list">
                            <% customers.forEach(customer => { %>
                                <%- include('partials/customer-row', { customer }) %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% if (customers.length === 0) { %>
                    <div class="text-center py-16 text-gray-400 text-sm italic">No records found.</div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- ADD CUSTOMER MODAL -->
    <div id="add-customer-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-300"
        onclick="closeModalOnBg(event, 'add-customer-modal')">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform" onclick="event.stopPropagation()">
            <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-lg font-black text-gray-800 uppercase tracking-tight">Add New Customer</h3>
                <button onclick="closeModal('add-customer-modal')" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-200 transition-colors text-gray-400">✕</button>
            </div>
            <form hx-post="/admin/customer/add" hx-target="#customer-list" hx-swap="afterbegin"
                hx-on::after-request="closeModal('add-customer-modal')" 
                data-toast="Customer profile created!"
                class="p-6 space-y-5">
                <input type="hidden" name="userId" value="<%= user.id %>">
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Full Name</label>
                    <input type="text" name="name" required placeholder="Full Name" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Phone Number</label>
                    <input type="text" name="phone" placeholder="978833xxxx" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Home Address</label>
                    <textarea name="address" rows="2" placeholder="City, Street..." class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-yellow-400 transition-all outline-none resize-none"></textarea>
                </div>
                <div class="flex gap-3 pt-4">
                    <button type="button" onclick="closeModal('add-customer-modal')"
                        class="flex-1 py-3.5 border border-gray-200 text-gray-600 rounded-2xl text-xs font-bold hover:bg-gray-50 transition-colors uppercase tracking-widest">Cancel</button>
                    <button type="submit"
                        class="flex-1 py-3.5 bg-yellow-400 shadow-xl shadow-yellow-200 hover:bg-yellow-500 text-gray-900 font-black rounded-2xl text-xs transition-transform active:scale-95 uppercase tracking-widest">Add Profile</button>
                </div>
            </form>
        </div>
    </div>

    <!-- EDIT CUSTOMER MODAL -->
    <div id="edit-customer-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4 transition-all duration-300"
        onclick="closeModalOnBg(event, 'edit-customer-modal')">
        <div id="edit-customer-content" class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform" onclick="event.stopPropagation()"></div>
    </div>

    <%- include('partials/bottom-nav') %>
    <%- include('partials/toast') %>

    <script>
        function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
        function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
        function closeModalOnBg(e, id) { if (e.target === e.currentTarget) closeModal(id); }

        function openEditCustomer(id) {
            openModal('edit-customer-modal');
            htmx.ajax('GET', `/admin/customer/${id}/edit-form`, { target: '#edit-customer-content' });
        }
    </script>
</body>

</html>